

Employee Details
<!DOCTYPE html>
<html>
<head>
    <title>Employee Salary</title>
    <script>
        function calculateSalary() {
            let basic = parseFloat(document.getElementById("basic").value) || 0;
            let da = parseFloat(document.getElementById("da").value) || 0;
            let hra = parseFloat(document.getElementById("hra").value) || 0;
            let allowance = parseFloat(document.getElementById("allowance").value) || 0;

            let total = basic + da + hra + allowance;
            document.getElementById("total").innerHTML = "Total Salary: " + total;
        }
    </script>
</head>
<body>
    <h2>Employee Details</h2>

    Employee ID: <input type="text"><br><br>
    Name: <input type="text"><br><br>
    Designation: <input type="text"><br><br>

    <h3>Salary Components</h3>
    Basic Pay: <input type="number" id="basic"><br><br>
    DA: <input type="number" id="da"><br><br>
    HRA: <input type="number" id="hra"><br><br>
    Allowance: <input type="number" id="allowance"><br><br>

    <button onclick="calculateSalary()">Calculate</button>

    <h3 id="total"></h3>
</body>
</html>




Registration form
<!DOCTYPE html>
<html>
<head>
    <title>Registration Form</title>
    <script>
        function validateForm() {
            let inputs = document.querySelectorAll("input, textarea");

            for (let i = 0; i < inputs.length; i++) {
                if (inputs[i].value.trim() === "") {
                    alert("All fields must be filled!");
                    return false;
                }
            }
            alert("Form submitted successfully!");
            return true;
        }
    </script>
</head>
<body>
    <h2>Registration Form</h2>

    <form onsubmit="return validateForm()">
        First Name: <input type="text"><br><br>
